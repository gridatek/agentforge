# ── Copy to .env and fill in. Only the provider you actually use is required. ──

# LLM layer — provider:model understood by langchain's init_chat_model.
#   anthropic:claude-opus-4-8 · openai:gpt-4o · ollama:llama3.1
CHAT_MODEL=anthropic:claude-opus-4-8
FAST_MODEL=anthropic:claude-haiku-4-5
MAX_TOKENS=4096

# Provider keys (set the one matching CHAT_MODEL / EMBEDDING_MODEL).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings — init_embeddings-style string. Dim MUST match the model.
#   ollama:nomic-embed-text (768) · openai:text-embedding-3-small (1536)
#   huggingface:BAAI/bge-small-en-v1.5 (384)  [needs the `local-embeddings` extra]
EMBEDDING_MODEL=ollama:nomic-embed-text
EMBEDDING_DIM=768

# Vector store backend: "pgvector" (default) or "qdrant" (needs the qdrant extra).
VECTOR_STORE_BACKEND=pgvector
# Postgres + pgvector. docker-compose provides this for you.
DATABASE_URL=postgresql+psycopg://agentforge:agentforge@localhost:5432/agentforge
COLLECTION_NAME=agentforge_documents
# Qdrant (used when VECTOR_STORE_BACKEND=qdrant). The qdrant overlay sets the URL.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Graph checkpointer: "memory" (in-process) or "postgres" (durable HITL/resume).
CHECKPOINT_BACKEND=memory

# RAG retrieval tuning.
RETRIEVAL_K=4
# Normalized relevance floor [0,1] (higher = stricter). Calibrate per embedding
# model; below it, chunks are dropped and the agent refuses (grounded refusal).
MIN_RELEVANCE=0.2
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Agent — override the system prompt to retarget the assistant at another domain
# (see examples/). Leave unset for the default banking-compliance persona.
# SYSTEM_PROMPT=

# Guardrails.
REDACT_PII=true

# Multi-tenancy — tenant id comes from the X-Tenant-ID header and namespaces
# graph threads, the approval queue, and the knowledge base (chunks are tagged
# at ingest, retrieval is filtered per tenant). Missing header falls back to
# DEFAULT_TENANT (single-tenant deploys need nothing here; legacy untagged
# chunks are auto-backfilled to DEFAULT_TENANT on startup). Set REQUIRE_TENANT
# to reject requests without a valid tenant id.
DEFAULT_TENANT=default
REQUIRE_TENANT=false

# Observability — "langsmith" | "langfuse" | "none".
OBSERVABILITY_BACKEND=none
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentforge
# Langfuse: keys from your project (cloud or self-hosted). With the self-host
# overlay (docker-compose.langfuse.yml), HOST is set to http://langfuse:3000.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Only for the self-hosted Langfuse server (docker-compose.langfuse.yml).
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# API gateway.
API_HOST=0.0.0.0
API_PORT=8000
